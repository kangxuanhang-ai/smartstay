# ==================== 数据库 ====================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/smartstay
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/smartstay

# ==================== JWT ====================
SECRET_KEY=smartstay-dev-secret-key-change-in-production

# ==================== 阿里云（人脸识别） ====================
# 在阿里云控制台 → AccessKey 管理 获取
ALIYUN_ACCESS_KEY_ID=你的AccessKeyID
ALIYUN_ACCESS_KEY_SECRET=你的AccessKeySecret
ALIYUN_REGION_ID=cn-shanghai
ALIYUN_FACE_DB_NAME=smartstay_faces

# ==================== DeepSeek AI ====================
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
